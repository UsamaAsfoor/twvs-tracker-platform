# ── Required (set as Fly secrets in production) ──────────────────────────────
ADMIN_PASSWORD=changeme
JWT_SECRET=generate-a-long-random-string

# ── Optional ─────────────────────────────────────────────────────────────────
JWT_EXPIRE_HOURS=24
SCRAPE_INTERVAL_HOURS=24

# Anthropic API key for LLM pipeline steps (required for scrape → publish)
# ANTHROPIC_API_KEY=sk-ant-...

# Patreon credentials — email + password only (NOT Google/GitHub sign-in).
# Used once to seed the headless browser session on Fly.io.
# PATREON_EMAIL=
# PATREON_PASSWORD=

# ── Fly.io / Docker (set in fly.toml [env], not secrets) ─────────────────────
# TWVS_REPO_ROOT=/app
# TWVS_DATA_DIR=/data
# TWVS_SESSION_DIR=/data/browser_session
