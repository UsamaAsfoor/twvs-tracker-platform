# Admin dashboard
ADMIN_PASSWORD=changeme
JWT_SECRET=generate-a-long-random-string
JWT_EXPIRE_HOURS=24

# Optional: Anthropic API key for LLM pipeline steps
# ANTHROPIC_API_KEY=sk-ant-...
# Or place key in tracker_repo/anthropic_api_key.txt

# Scheduled scrape interval (hours)
SCRAPE_INTERVAL_HOURS=24

# Repo paths (defaults to tracker_repo/)
# TWVS_REPO_ROOT=/path/to/tracker_repo
# TWVS_DATA_DIR=/path/to/tracker_repo/data
# TWVS_SESSION_DIR=/path/to/tracker_repo/browser_session
