# ── Required (set as Fly secrets in production) ──────────────────────────────
ADMIN_PASSWORD=changeme
JWT_SECRET=generate-a-long-random-string

# ── Optional ─────────────────────────────────────────────────────────────────
JWT_EXPIRE_HOURS=24
SCRAPE_INTERVAL_HOURS=24

# Anthropic API key for LLM pipeline steps (required for scrape → publish)
# ANTHROPIC_API_KEY=sk-ant-...

# Patreon OAuth (recommended) — register redirect URI in Patreon developer portal:
#   {PUBLIC_BASE_URL}/api/admin/patreon/oauth/callback
# PATREON_CLIENT_ID=
# PATREON_CLIENT_SECRET=
# PUBLIC_BASE_URL=https://twvs-tracker.fly.dev

# Patreon credentials fallback — email + password only (NOT Google/GitHub sign-in).
# PATREON_EMAIL=
# PATREON_PASSWORD=

# ── Fly.io / Docker (set in fly.toml [env], not secrets) ─────────────────────
# TWVS_REPO_ROOT=/app
# TWVS_DATA_DIR=/data
# TWVS_SESSION_DIR=/data/browser_session
